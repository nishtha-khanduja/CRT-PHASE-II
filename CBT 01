Q2.
Given an array of integers nums , find and return the second largest element in the array without sorting
. If there is no second largest element (i.e., all elements are thesame or there is only one element), return -1




#include <iostream>
#include <vector>
#include <climits>
using namespace std;

int n;
int findSecondLargest(vector<int> &nums,n){
int max=INT_MIN;
int smax= INT_MIN;
for (int i=0; i<n;i++){
if (nums[i]>max){
smax = max;
max= nums[i];
}
else if(nums[i]>smax && nums[i]<max){
smax=nums[i];
}
}
return (smax==INT_MIN)? -1 : smax;
}
int main(){
int n;
cin>>n;
vector <int> nums(n);
for (int i=0; i<n; i++){
cin>>nums[i];
}
cout<< findSecondLargest(nums,n);
return 0;

}










